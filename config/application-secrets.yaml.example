spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/sky_online_db_local
    username: postgres
    password: your_db_password

app:
  admin:
    bootstrap:
      username: your_admin_username
      password: your_admin_password

# Add any other local-only secrets here.
# This file's real version is ignored by Git:
#   config/application-secrets.yaml
